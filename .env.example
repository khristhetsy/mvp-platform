# CapitalOS environment templates
# Copy the file that matches your target tier. Never commit real secrets.

# --- Core (all tiers) ---
APP_ENV=local
# local | staging | production

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never import in client components or browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public app URL (OAuth redirects, email links). Also accepts NEXT_PUBLIC_SITE_URL for legacy configs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional legacy alias (some modules may read it)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google OAuth (Calendar/Meet — server-only except redirect URI) ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# 32+ characters — openssl rand -base64 32
TOKEN_ENCRYPTION_SECRET=your-long-random-encryption-secret

# --- Safety (local only) ---
# Optional: warn if local env points at production Supabase (host only, e.g. abcdef.supabase.co)
# CAPITALOS_PRODUCTION_SUPABASE_HOST=your-prod-ref.supabase.co

# --- Vercel Cron (server-only) ---
# Required for /api/cron/run-orchestration on staging/production.
# Vercel sends: Authorization: Bearer <CRON_SECRET>
# Generate: openssl rand -base64 32
CRON_SECRET=your-long-random-cron-secret

# --- Transactional email (Resend) ---
# Required for email alerts (deal room questions, doc requests, investor interest, team invites).
# Get your API key at https://resend.com/api-keys
# Falls back to a no-op log in development if not set.
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=CapitalOS <no-reply@mail.capitalos.io>
# Webhook secret for Resend delivery events (optional)
# RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# --- LemonSqueezy (billing) ---
# Required for checkout, webhooks, and plan enforcement.
# Get keys at https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
# Variant IDs for each plan (Settings → Products → Variants)
LEMONSQUEEZY_VARIANT_ID_BASIC=your_basic_variant_id
LEMONSQUEEZY_VARIANT_ID_PROFESSIONAL=your_professional_variant_id

# --- Analytics (PostHog) ---
# Optional — remove to disable product analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Beta gate ---
# Set to "true" to restrict signup to invited users only
NEXT_PUBLIC_PRIVATE_BETA_MODE=false
PRIVATE_BETA_MODE=false

# --- Transactional email (secondary sender) ---
# Falls back to EMAIL_FROM if not set; override only if you need a separate from-address
# TRANSACTIONAL_EMAIL_FROM=CapitalOS <no-reply@mail.capitalos.io>

# --- Admin + support ---
# Email address shown in admin escalation notifications
ADMIN_SUPPORT_EMAIL=support@capitalos.io

# --- Learning video (optional — Phase 2) ---
# Required only if you use AI-generated course videos
# HEYGEN_API_KEY=your_heygen_api_key
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# REMOTION_RENDER_WEBHOOK_URL=https://your-render-endpoint/webhook

# --- Marketing ---
# Required only if you use the marketing campaign module
# MARKETING_UNSUBSCRIBE_SECRET=your_unsubscribe_hmac_secret

# --- Misc ---
# DATABASE_URL=postgresql://...   # backup scripts / Prisma — not required for Next.js runtime
# ANTHROPIC_API_KEY=sk-ant-...   # Claude AI — chat, diligence, coach, CMO bot
# NEXT_PUBLIC_SITE_URL=            # legacy alias for NEXT_PUBLIC_APP_URL
