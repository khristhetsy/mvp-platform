# Staging — set in Vercel Preview / Staging project environment variables.
# Use a dedicated STAGING Supabase project (never production).
# See docs/environments.md

APP_ENV=staging

NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

NEXT_PUBLIC_APP_URL=https://staging.your-domain.com

GOOGLE_CLIENT_ID=your-staging-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-staging-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://staging.your-domain.com/api/integrations/google/callback
TOKEN_ENCRYPTION_SECRET=your-staging-encryption-secret-min-32-chars

# Email — Resend (outbound) + inbound webhook for inbox replies
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=CapitalOS <no-reply@mail.staging.your-domain.com>
INBOUND_EMAIL_DOMAIN=mail.staging.your-domain.com
INBOUND_WEBHOOK_SECRET=your-inbound-webhook-shared-secret

# Cron (Vercel) — required for orchestration, digests, and meeting reminders
CRON_SECRET=your-staging-cron-shared-secret

# Optional
# DATABASE_URL=postgresql://...
# ANTHROPIC_API_KEY=sk-ant-...   # Claude AI
