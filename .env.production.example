# Production — set in Vercel Production environment variables only.
# Use your PRODUCTION Supabase project.
# See docs/environments.md and docs/deployment-checklist.md

APP_ENV=production

NEXT_PUBLIC_SUPABASE_URL=https://your-production-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

NEXT_PUBLIC_APP_URL=https://app.your-domain.com

GOOGLE_CLIENT_ID=your-production-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-production-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://app.your-domain.com/api/integrations/google/callback
TOKEN_ENCRYPTION_SECRET=your-production-encryption-secret-min-32-chars

# Optional
# DATABASE_URL=postgresql://...   # required for npm run ops:backup-db
# ANTHROPIC_API_KEY=sk-ant-...   # Claude AI
