{
  "name": "icapos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:staging": "APP_ENV=staging next build",
    "build:production": "APP_ENV=production next build",
    "check:env": "node scripts/check-env.mjs",
    "check:predeploy": "node scripts/predeploy-check.mjs",
    "check:predeploy:full": "node scripts/predeploy-check.mjs --render --require-built",
    "db:types": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > src/lib/supabase/types.ts",
    "db:types:check": "node scripts/check-types-fresh.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --project tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:investor-express-interest": "node scripts/test-investor-express-interest.mjs",
    "test:investor-crm-pipeline": "node --experimental-strip-types scripts/test-investor-crm-pipeline.ts",
    "ops:check-env": "node scripts/check-env.mjs",
    "ops:backup-db": "bash scripts/backup-db.sh",
    "ops:backup-storage": "bash scripts/backup-storage.sh",
    "ops:verify-backup": "bash scripts/verify-backup.sh",
    "ops:export-metadata": "node scripts/export-operational-metadata.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@next/third-parties": "^16.2.9",
    "@sentry/nextjs": "^10.57.0",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.511.0",
    "next": "16.2.6",
    "next-intl": "^4.13.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.8.69",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "posthog-js": "^1.383.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
