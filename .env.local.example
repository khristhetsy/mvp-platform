# Local development — copy to .env.local and fill in values from your DEV Supabase project.
# See docs/environments.md

APP_ENV=local

NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

NEXT_PUBLIC_APP_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
TOKEN_ENCRYPTION_SECRET=your-long-random-encryption-secret-min-32-chars

# Warn if you accidentally point local at production Supabase:
# CAPITALOS_PRODUCTION_SUPABASE_HOST=your-prod-ref.supabase.co

# Optional
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/capitalos_dev
# OPENAI_API_KEY=sk-...
